# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_ID=       # your personal chat ID for error alerts

# ─── OKX API ─────────────────────────────────────────────────────────────────
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# ─── Trading Mode ────────────────────────────────────────────────────────────
LIVE_TRADING=false
DEMO_TRADING=true        # uses OKX paper trading (x-simulated-trading: 1)

# ─── Instruments & Timeframes ────────────────────────────────────────────────
SYMBOLS=BTC-USDT-SWAP,ETH-USDT-SWAP,SOL-USDT-SWAP
TIMEFRAMES=15m,1H,4H

# ─── Risk Management ─────────────────────────────────────────────────────────
RISK_PER_TRADE=1          # % of account per trade
MAX_DAILY_LOSS=3          # % — stop trading for the day
MAX_OPEN_POSITIONS=3
MAX_LOSSES_IN_ROW=3       # consecutive losses → pause 24h

# ─── Strategy ────────────────────────────────────────────────────────────────
AUTO_OPTIMIZE=false       # apply learning recommendations automatically
MIN_SIGNAL_CONFIDENCE=6   # 1-10, minimum to publish signal

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=./trading.db

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
